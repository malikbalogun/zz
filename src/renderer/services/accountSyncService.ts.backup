import { authenticatePanel, fetchAccounts, exportToken } from './panelService';
import { addAccount, getAccounts, updateAccount, deleteAccount } from './accountService';
import { getSystemTags } from './tagService';
import { getSettings } from './settingsService';
import { UIAccount } from '../../types/store';

/**
 * Sync accounts from a panel.
 * 1. Authenticate panel (if not already).
 * 2. Fetch accounts via panel API.
 * 3. Convert each to UIAccount, assign tags (panel tag, admin if applicable, autorefresh).
 * 4. Store new/updated accounts.
 */
export async function syncPanelAccounts(panelId: string): Promise<UIAccount[]> {
  // Authenticate panel (will update token)
  const panel = await authenticatePanel(panelId);
  
  // Fetch accounts from panel
  const remoteAccounts = await fetchAccounts(panel);
  
  // Determine panel's system tag (Production/Backup)
  const panelTag = panel.name.toLowerCase().includes('backup') ? 'backup' : 'production';
  
  // Get settings for autorefresh tag
  const settings = await getSettings();
  const autoRefreshTagId = settings.refresh.tagId || 'autorefresh';
  
  // Get existing accounts to avoid duplicates
  const existing = await getAccounts();
  
  const added: UIAccount[] = [];
  
  for (const remote of remoteAccounts) {
    // Determine if admin (assuming remote.isAdmin exists; fallback to email pattern)
    const isAdmin = remote.isAdmin === true || remote.email?.toLowerCase().includes('admin');
    
    // Build tags
    const tags = [panelTag];
    if (isAdmin) tags.push('admin');
    if (autoRefreshTagId) tags.push(autoRefreshTagId);
    
    // Find existing account by email + panelId
    const existingAccount = existing.find(
      a => a.email === remote.email && a.panelId === panelId
    );
    
    const accountData: Omit<UIAccount, 'id'> = {
      email: remote.email,
      name: remote.name || remote.email.split('@')[0],
      panelId,
      added: existingAccount?.added || new Date().toISOString(),
      status: 'active', // TODO: determine from remote status
      tags,
      auth: {
        type: 'token',
        clientId: remote.clientId,
        authorityEndpoint: remote.authorityEndpoint,
        refreshToken: remote.refreshToken,
      },
      lastRefresh: remote.lastRefresh || existingAccount?.lastRefresh,
      notes: remote.notes,
    };
    
    if (existingAccount) {
      // Update existing
      const updated = await updateAccount(existingAccount.id, accountData);
      added.push(updated);
    } else {
      // Add new
      const newAccount = await addAccount(accountData);
      added.push(newAccount);
    }
  }
  
  // Optionally remove accounts that are no longer on the panel
  // (for simplicity, we keep them; they'll get detached tag when panel is deleted)
  
  return added;
}

/**
 * Import an account via cookie capture.
 * Opens a browser window to capture cookies, then stores as UIAccount with Cookie‑Import tag.
 */
export async function importAccountViaCookie(url: string, email: string): Promise<UIAccount> {
  // TODO: call IPC to capture cookies
  const result = await window.electron.actions.captureCookies(url);
  if (!result.success) {
    throw new Error(`Cookie capture failed: ${result.message}`);
  }
  
  const settings = await getSettings();
  const autoRefreshTagId = settings.refresh.tagId || 'autorefresh';
  
  const tags = ['cookie-import'];
  if (autoRefreshTagId) tags.push(autoRefreshTagId);
  
  const accountData: Omit<UIAccount, 'id'> = {
    email,
    added: new Date().toISOString(),
    status: 'active',
    tags,
    auth: {
      type: 'cookie',
      cookies: result.cookies, // encrypted later by accountService?
    },
  };
  
  return addAccount(accountData);
}

/**
 * Add an account via credentials (username/password).
 * Performs login to panel and obtains token.
 */
export async function addAccountViaCredentials(
  panelId: string,
  email: string,
  password: string
): Promise<UIAccount> {
  const panel = await authenticatePanel(panelId);
  // TODO: call panel API to login as this user and obtain token
  // For now simulate
  const settings = await getSettings();
  const autoRefreshTagId = settings.refresh.tagId || 'autorefresh';
  
  const tags = ['credential'];
  if (autoRefreshTagId) tags.push(autoRefreshTagId);
  
  const accountData: Omit<UIAccount, 'id'> = {
    email,
    panelId,
    added: new Date().toISOString(),
    status: 'active',
    tags,
    auth: {
      type: 'credential',
      username: email,
      passwordEncrypted: password, // will be encrypted by accountService
    },
  };
  
  return addAccount(accountData);
}

/**
 * Harvest other accounts from the same panel using an admin account.
 * Calls panel API to list associated accounts, then imports them with Admin‑Harvest tag.
 */
export async function harvestAssociatedAccounts(adminAccountId: string): Promise<UIAccount[]> {
  // TODO: call IPC admin:harvest with accountId
  const associated = await window.electron.actions.adminHarvest(adminAccountId);
  
  const settings = await getSettings();
  const autoRefreshTagId = settings.refresh.tagId || 'autorefresh';
  
  const added: UIAccount[] = [];
  for (const acc of associated) {
    const tags = ['admin-harvest'];
    if (autoRefreshTagId) tags.push(autoRefreshTagId);
    
    const accountData: Omit<UIAccount, 'id'> = {
      email: acc.email,
      panelId: acc.panelId,
      added: new Date().toISOString(),
      status: acc.status || 'active',
      tags,
      auth: acc.auth,
    };
    const newAccount = await addAccount(accountData);
    added.push(newAccount);
  }
  return added;
}

/**
 * Open mailbox for an account.
 * Retrieves token (or uses cookies) and launches browser window.
 */
export async function openMailbox(accountId: string): Promise<void> {
  // TODO: retrieve account, get token/cookies, open browser
  await window.electron.actions.openMailbox(accountId);
}