import { useState, useEffect } from 'react';

import PanelForm from './components/PanelForm';
import AccountsView from './components/AccountsView';
import SettingsView from './components/SettingsView';
import * as panelService from './services/panelService';
import { Panel } from '../types/panel';

type View = 'panels' | 'accounts' | 'settings';

const App = () => {
  const [activeView, setActiveView] = useState<View>('panels');
  const [showForm, setShowForm] = useState(false);
  const [panels, setPanels] = useState<Panel[]>([]);
  const [sidebarExpanded, setSidebarExpanded] = useState(true);
  const [sidebarHover, setSidebarHover] = useState(false);

  // Load panels on mount
  useEffect(() => {
    loadPanels();
  }, []);

  const loadPanels = async () => {
    try {
      const data = await panelService.getPanels();
      setPanels(data);
    } catch (error) {
      console.error('Failed to load panels:', error);
    }
  };

  const handleAddPanel = async (panel: Omit<Panel, 'id' | 'status' | 'passwordEncrypted'> & { password: string }) => {
    await panelService.addPanel(panel);
    await loadPanels(); // refresh list
    setShowForm(false);
  };

  const handleDeletePanel = async (id: string) => {
    await panelService.deletePanel(id);
    await loadPanels();
  };

  const handleTestConnection = async (panelId: string) => {
    try {
      await panelService.authenticatePanel(panelId);
      await loadPanels(); // update status
    } catch (error) {
      console.error('Connection test failed:', error);
    }
  };

  const sidebarWidth = sidebarExpanded || sidebarHover ? 'w-64' : 'w-16';

  return (
    <div className="flex h-screen bg-white text-gray-800">
      {/* Sidebar */}
      <div
        className={`${sidebarWidth} border-r border-gray-300 p-4 flex flex-col transition-all duration-300 ease-in-out bg-gradient-to-b from-blue-600 to-blue-700`}
        onMouseEnter={() => setSidebarHover(true)}
        onMouseLeave={() => setSidebarHover(false)}
      >
        <div className="flex items-center justify-center mb-10">
          <div className="w-10 h-10 rounded-lg bg-white flex items-center justify-center shadow">
            <svg className="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M4 6a2 2 0 012-2h12a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V6z" />
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M9 3v18M3 9h18" />
            </svg>
          </div>
          {(sidebarExpanded || sidebarHover) && (
            <h1 className="text-2xl font-bold ml-3 text-white">Panel Manager</h1>
          )}
        </div>
        <nav className="space-y-3 flex-1">
          <button
            onClick={() => setActiveView('panels')}
            className={`w-full flex items-center ${sidebarExpanded || sidebarHover ? 'justify-start px-4' : 'justify-center px-2'} py-3 rounded-lg transition-all ${activeView === 'panels' ? 'bg-blue-800 text-white shadow' : 'bg-blue-700/80 hover:bg-blue-800 text-white'}`}
            title="Panels"
          >
            <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="1.5" d="M4 6a2 2 0 012-2h12a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V6z" />
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="1.5" d="M9 3v18M3 9h18" />
            </svg>
            {(sidebarExpanded || sidebarHover) && <span className="ml-3 font-medium">Panels</span>}
          </button>
          <button
            onClick={() => setActiveView('accounts')}
            className={`w-full flex items-center ${sidebarExpanded || sidebarHover ? 'justify-start px-4' : 'justify-center px-2'} py-3 rounded-lg transition-all ${activeView === 'accounts' ? 'bg-blue-800 text-white shadow' : 'bg-blue-700/80 hover:bg-blue-800 text-white'}`}
            title="Accounts"
          >
            <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            {(sidebarExpanded || sidebarHover) && <span className="ml-3 font-medium">Accounts</span>}
          </button>
          <button
            onClick={() => setActiveView('settings')}
            className={`w-full flex items-center ${sidebarExpanded || sidebarHover ? 'justify-start px-4' : 'justify-center px-2'} py-3 rounded-lg transition-all ${activeView === 'settings' ? 'bg-blue-800 text-white shadow' : 'bg-blue-700/80 hover:bg-blue-800 text-white'}`}
            title="Settings"
          >
            <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {(sidebarExpanded || sidebarHover) && <span className="ml-3 font-medium">Settings</span>}
          </button>
        </nav>
        <div className="mt-auto pt-6 border-t border-blue-500">
          {(sidebarExpanded || sidebarHover) && <div className="text-sm text-blue-200 mb-3">v0.1.0</div>}
          <button
            onClick={() => setSidebarExpanded(!sidebarExpanded)}
            className="w-full py-2 bg-blue-500 hover:bg-blue-400 text-white rounded-lg font-medium flex items-center justify-center shadow"
            title={sidebarExpanded ? 'Collapse sidebar' : 'Expand sidebar'}
          >
            <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d={sidebarExpanded ? "M13 5l7 7-7 7M5 5l7 7-7 7" : "M11 19l7-7-7-7M5 19l7-7-7-7"} />
            </svg>
            {(sidebarExpanded || sidebarHover) && <span className="ml-2">{sidebarExpanded ? 'Collapse' : 'Expand'}</span>}
          </button>
        </div>
      </div>
      {/* Main Content */}
      <div className="flex-1 p-8 overflow-auto">
        {activeView === 'panels' && (
          <div className="max-w-6xl">
            <div className="bg-gradient-to-r from-blue-600 to-blue-700 rounded-2xl p-8 mb-8 text-white shadow-xl">
              <h2 className="text-4xl font-bold mb-4">Panel Management</h2>
              <p className="text-blue-100 text-lg">
                Connect to your webmail panels, sync tokens, and keep accounts alive.
              </p>
            </div>

            {showForm ? (
              <div className="mb-8">
                <PanelForm
                  onSuccess={handleAddPanel}
                  onCancel={() => setShowForm(false)}
                />
              </div>
            ) : (
              panels.length === 0 && (
                <div className="mb-8">
                  <div className="bg-gradient-to-br from-gray-50 to-white border border-gray-300 rounded-2xl p-8 shadow-lg">
                    <h3 className="text-2xl font-semibold mb-4 text-gray-900">Welcome to Panel Manager</h3>
                    <p className="text-gray-700 mb-6 max-w-2xl">
                      Add your first webmail panel by clicking "Add Panel" above. You'll need the panel URL and admin credentials.
                      Once connected, you can sync accounts and export refresh tokens.
                    </p>
                    <button
                      onClick={() => setShowForm(true)}
                      className="px-6 py-3 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white rounded-lg font-medium shadow"
                    >
                      Add Your First Panel
                    </button>
                  </div>
                </div>
              )
            )}

            {panels.length > 0 && (
              <div className="mt-8">
                <div className="flex justify-between items-center mb-6">
                  <h3 className="text-2xl font-bold text-gray-900">Connected Panels</h3>
                  {!showForm && (
                    <button
                      onClick={() => setShowForm(true)}
                      className="px-5 py-2.5 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white rounded-lg font-medium flex items-center shadow"
                    >
                      <span className="mr-2">+</span> Add Panel
                    </button>
                  )}
                </div>
                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                  {panels.map(panel => (
                    <div key={panel.id} className="bg-gradient-to-br from-white to-gray-50 border border-gray-300 rounded-xl p-6 hover:border-blue-400 hover:shadow-xl transition-all duration-300 group">
                      <div className="flex justify-between items-start mb-4">
                        <div>
                          <div className="flex items-center">
                            <div className="w-10 h-10 rounded-lg bg-gradient-to-r from-blue-100 to-blue-200 flex items-center justify-center mr-3 shadow">
                              <svg className="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                              </svg>
                            </div>
                            <div>
                              <h4 className="font-bold text-lg truncate text-gray-900">{panel.name}</h4>
                              <p className="text-gray-500 text-sm truncate">{panel.url}</p>
                            </div>
                          </div>
                        </div>
                        <div className="flex items-center">
                          <div className={`w-3 h-3 rounded-full mr-2 ${panel.status === 'connected' ? 'bg-green-500 animate-pulse' : panel.status === 'error' ? 'bg-red-500' : 'bg-yellow-500'}`}></div>
                          <span className="text-sm capitalize text-gray-700">{panel.status}</span>
                        </div>
                      </div>
                      <div className="mb-5">
                        <p className="text-gray-700 text-sm">
                          <span className="text-gray-500">Admin:</span> {panel.username}
                        </p>
                        {panel.lastSync && (
                          <p className="text-gray-700 text-sm mt-1">
                            <span className="text-gray-500">Last sync:</span> {new Date(panel.lastSync).toLocaleString()}
                          </p>
                        )}
                        {panel.error && (
                          <p className="text-red-600 text-sm mt-1 truncate" title={panel.error}>
                            Error: {panel.error}
                          </p>
                        )}
                      </div>
                      <div className="flex space-x-2">
                        <button
                          onClick={() => handleTestConnection(panel.id)}
                          className="flex-1 px-3 py-2 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white rounded-lg font-medium text-sm transition-all shadow"
                        >
                          Test Connection
                        </button>
                        <button
                          onClick={() => handleDeletePanel(panel.id)}
                          className="px-3 py-2 bg-gradient-to-r from-gray-200 to-gray-300 hover:from-red-500 hover:to-red-600 hover:text-white text-gray-800 rounded-lg font-medium text-sm transition-all"
                          title="Delete panel"
                        >
                          Delete
                        </button>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}

        {activeView === 'accounts' && <AccountsView />}
        {activeView === 'settings' && <SettingsView />}
      </div>
    </div>
  );
};

export default App;